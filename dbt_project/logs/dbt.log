FROM "survey_db"."dwh_staging"."stg_survey_responses" s,
     LATERAL UNNEST(STRING_TO_ARRAY(s.database_have_worked, ';')) AS db(elem)
WHERE s.database_have_worked IS NOT NULL
  AND TRIM(db.elem) IS NOT NULL
  AND TRIM(db.elem) != ''
  );
